---
import Layout from "./Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import { getLangFromUrl } from "@/i18n/utils";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<Layout title={title} description={description} noindex={true}>
  <Navbar />
  <main class="pt-28 md:pt-36 pb-20 md:pb-24">
    <article class="max-w-3xl mx-auto px-6">
      <header class="mb-12">
        <a
          href={`/${lang}/`}
          class="inline-flex items-center gap-2 text-amber text-sm font-medium mb-6 hover:text-amber-light transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          {lang === "de" ? "Zurück zur Startseite" : "Back to homepage"}
        </a>
        <h1 class="text-3xl md:text-5xl font-display font-bold text-text-heading leading-tight">
          {title}
        </h1>
      </header>

      <div class="prose prose-invert prose-amber max-w-none
        [&_h2]:text-2xl [&_h2]:md:text-3xl [&_h2]:font-display [&_h2]:font-bold [&_h2]:text-text-heading [&_h2]:mt-12 [&_h2]:mb-4
        [&_h3]:text-xl [&_h3]:font-display [&_h3]:font-semibold [&_h3]:text-text-heading [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-text-muted [&_p]:leading-relaxed [&_p]:mb-6
        [&_ul]:text-text-muted [&_ul]:space-y-2 [&_ul]:mb-6 [&_ul]:pl-6
        [&_ol]:text-text-muted [&_ol]:space-y-2 [&_ol]:mb-6 [&_ol]:pl-6
        [&_li]:text-text-muted
        [&_strong]:text-text-heading
        [&_a]:text-amber [&_a]:underline [&_a]:underline-offset-4 [&_a]:hover:text-amber-light [&_a]:transition-colors
        [&_address]:text-text-muted [&_address]:not-italic [&_address]:leading-relaxed [&_address]:mb-6
      ">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</Layout>
