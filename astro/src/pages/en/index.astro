---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Hero from "@/components/Hero.astro";
import Video from "@/components/Video.astro";
import FeatureCenter from "@/components/FeatureCenter.astro";
import FeatureGrill from "@/components/FeatureGrill.astro";
import FeatureStyle from "@/components/FeatureStyle.astro";
import FeatureQuality from "@/components/FeatureQuality.astro";
import Testimonials from "@/components/Testimonials.astro";
import Safety from "@/components/Safety.astro";
import CTA from "@/components/CTA.astro";
import Footer from "@/components/Footer.astro";
