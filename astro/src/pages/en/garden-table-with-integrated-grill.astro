<script>
  const track = document.getElementById("carousel-track") as HTMLElement;
  const dots = document.querySelectorAll("#carousel-dots button");
  const total = dots.length;
  let current = 0;

  function goTo(index: number) {
    current = ((index % total) + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.classList.toggle("bg-amber", i === current);
      d.classList.toggle("bg-border", i !== current);
    });
  }

  document.getElementById("carousel-prev")!.addEventListener("click", () => goTo(current - 1));
  document.getElementById("carousel-next")!.addEventListener("click", () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener("click", () => goTo(Number((dot as HTMLElement).dataset.index)));
  });

  let autoplay = setInterval(() => goTo(current + 1), 4000);
  document.getElementById("carousel")!.addEventListener("pointerenter", () => clearInterval(autoplay));
  document.getElementById("carousel")!.addEventListener("pointerleave", () => {
    autoplay = setInterval(() => goTo(current + 1), 4000);
  });
</script>
