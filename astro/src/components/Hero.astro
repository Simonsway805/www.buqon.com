---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="hero" class="relative bg-black">
  <div id="hero-inner" class="relative overflow-hidden bg-black pb-4 md:pb-6 lg:sticky lg:top-0 lg:h-screen">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_80%,_rgba(212,160,83,0.06)_0%,_transparent_60%)]"></div>
    </div>

    <div class="relative z-10 text-center px-6 pt-24 md:pt-32 lg:pt-[12vh]">
      <h1
        class="hero-animate-title font-display font-bold text-text-heading leading-none tracking-tight"
        style="font-size: clamp(5rem, 18vw, 16rem);"
      >
        DINE
      </h1>
      <p class="hero-animate-subtitle text-lg md:text-2xl lg:text-3xl font-display text-text-muted/80 tracking-wide mt-1 md:mt-3">
        {t("hero.title")}
      </p>
    </div>

    <div class="hero-animate-image relative z-20 w-full max-w-4xl mx-auto px-2 md:px-6 mt-4 md:mt-6 lg:mt-8" id="hero-table-wrap">
      <div class="relative overflow-hidden" style="max-height: 40vh;">
        <div
          class="hero-animate-glow absolute -inset-x-12 -bottom-8 top-1/3 bg-[radial-gradient(ellipse_at_50%_40%,_rgba(212,160,83,0.12)_0%,_transparent_70%)] blur-2xl pointer-events-none"
        ></div>
        <img
          src="/images/hero-table.webp"
          alt="Buqon DINE Table"
          width="1024"
          height="154"
          fetchpriority="high"
          decoding="async"
          class="relative w-full h-auto object-cover object-top drop-shadow-[0_20px_60px_rgba(0,0,0,0.8)]"
        />
      </div>
    </div>

    <div class="hero-animate-scroll relative z-30 mt-8 flex justify-center lg:absolute lg:bottom-6 lg:left-1/2 lg:-translate-x-1/2 lg:mt-0">
      <div class="flex flex-col items-center gap-2 text-text-muted/60">
        <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
        <div class="w-px h-10 relative overflow-hidden">
          <div class="scroll-line-animate w-full h-full bg-gradient-to-b from-text-muted/40 to-transparent"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const heroInner = document.getElementById("hero-inner");
  const heroWrap = document.getElementById("hero-table-wrap");

  if (heroInner) {
    window.addEventListener("scroll", () => {
      const rect = heroInner.getBoundingClientRect();
      const progress = Math.min(1, Math.max(0, -rect.top / rect.height));
      heroInner.style.opacity = String(1 - progress * 1.2);
      if (heroWrap) {
        heroWrap.style.transform = `translateY(${-progress * 80}px) scale(${1 + progress * 0.15})`;
      }
    }, { passive: true });
  }
</script>
