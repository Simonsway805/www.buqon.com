---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="hero" class="relative bg-black">
  <div id="hero-inner" class="relative overflow-hidden bg-black pb-4 md:pb-6 lg:sticky lg:top-0 lg:h-screen">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_80%,_rgba(212,160,83,0.06)_0%,_transparent_60%)]"></div>
    </div>

    <div class="relative z-10 text-center px-6 pt-24 md:pt-32 lg:pt-[12vh]">
      <h1
        id="hero-dine"
        class="font-display font-bold text-text-heading leading-none tracking-tight"
        style="font-size: clamp(5rem, 18vw, 16rem);"
      >
        DINE
      </h1>
      <p
        id="hero-subtitle"
        class="text-lg md:text-2xl lg:text-3xl font-display text-text-muted/80 tracking-wide mt-1 md:mt-3"
      >
        {t("hero.title")}
      </p>
    </div>

    <div class="relative z-20 w-full max-w-4xl mx-auto px-2 md:px-6 mt-4 md:mt-6 lg:mt-8" id="hero-table-wrap">
      <div class="relative overflow-hidden" style="max-height: 40vh;">
        <div
          id="hero-table-glow"
          class="absolute -inset-x-12 -bottom-8 top-1/3 bg-[radial-gradient(ellipse_at_50%_40%,_rgba(212,160,83,0.12)_0%,_transparent_70%)] blur-2xl pointer-events-none opacity-0"
        ></div>
        <img
          id="hero-table-img"
          src="/images/hero-table.png"
          alt="Buqon DINE Table"
          class="relative w-full h-auto object-cover object-top drop-shadow-[0_20px_60px_rgba(0,0,0,0.8)]"
        />
      </div>
    </div>

    <div class="relative z-30 mt-8 flex justify-center lg:absolute lg:bottom-6 lg:left-1/2 lg:-translate-x-1/2 lg:mt-0" id="scroll-indicator">
      <div class="flex flex-col items-center gap-2 text-text-muted/60">
        <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
        <div class="w-px h-10 relative overflow-hidden">
          <div class="w-full h-full bg-gradient-to-b from-text-muted/40 to-transparent" id="scroll-line"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const introTl = gsap.timeline({ delay: 0.2 });

  introTl
    .from("#hero-dine", {
      y: 60,
      opacity: 0,
      duration: 1.2,
      ease: "power4.out",
    })
    .from(
      "#hero-subtitle",
      {
        y: 30,
        opacity: 0,
        duration: 0.9,
        ease: "power3.out",
      },
      "-=0.6"
    )
    .from(
      "#hero-table-img",
      {
        y: 120,
        opacity: 0,
        scale: 0.92,
        duration: 1.4,
        ease: "power3.out",
      },
      "-=0.5"
    )
    .to(
      "#hero-table-glow",
      {
        opacity: 1,
        duration: 1.2,
        ease: "power2.out",
      },
      "-=0.8"
    )
    .from(
      "#scroll-indicator",
      {
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.4"
    );

  gsap.to("#scroll-line", {
    y: "100%",
    duration: 1.5,
    ease: "power1.inOut",
    repeat: -1,
    yoyo: true,
  });

  const scrollTl = gsap.timeline({
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 0.8,
    },
  });

  scrollTl
    .to(
      "#hero-dine",
      {
        y: -150,
        opacity: 0,
        scale: 1.1,
        duration: 1,
        ease: "none",
      },
      0
    )
    .to(
      "#hero-subtitle",
      {
        y: -100,
        opacity: 0,
        duration: 0.8,
        ease: "none",
      },
      0
    )
    .to(
      "#hero-table-wrap",
      {
        y: -80,
        scale: 1.15,
        duration: 1,
        ease: "none",
      },
      0
    )
    .to(
      "#hero-table-glow",
      {
        opacity: 0.3,
        scale: 1.4,
        duration: 1,
        ease: "none",
      },
      0
    )
    .to(
      "#scroll-indicator",
      {
        opacity: 0,
        duration: 0.3,
        ease: "none",
      },
      0
    )
    .to(
      "#hero-inner",
      {
        opacity: 0,
        duration: 1,
        ease: "none",
      },
      0.3
    );
</script>
