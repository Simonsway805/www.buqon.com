---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const year = new Date().getFullYear();

const footerLinks =
  lang === "de"
    ? [
        { label: "Impressum", href: "/de/impressum/" },
        { label: "AGB", href: "/de/agb/" },
        { label: "Datenschutz", href: "/de/datenschutz/" },
        { label: "Widerrufsrecht", href: "/de/widerrufsrecht/" },
      ]
    : [
        { label: "Imprint", href: "/en/imprint/" },
        { label: "Terms", href: "/en/terms/" },
        { label: "Privacy", href: "/en/privacy/" },
        { label: "Withdrawal", href: "/en/withdrawal/" },
      ];
---

<footer class="relative border-t border-border bg-bg-surface/30">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-4 gap-12 mb-12">
      <div class="md:col-span-2">
        <a href={`/${lang}/`} class="inline-block mb-4">
          <span class="text-3xl font-bold tracking-tight text-text-heading font-display">
            BUQON
          </span>
        </a>
        <p class="text-text-muted leading-relaxed max-w-sm">
          {lang === "de"
            ? "Multifunktionaler Edelstahl Gartentisch mit Grilleinsatz. Gemeinsam Grillen – gemeinsam genießen."
            : "Multifunctional stainless steel garden table with integrated grill. Grill together – enjoy together."}
        </p>

        <div class="flex gap-4 mt-6">
          <a
            href="https://www.facebook.com/buqoncraft"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-bg-elevated border border-border flex items-center justify-center text-text-muted hover:text-amber hover:border-amber/30 transition-all duration-300"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href="https://www.instagram.com/buqoncraft/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-bg-elevated border border-border flex items-center justify-center text-text-muted hover:text-amber hover:border-amber/30 transition-all duration-300"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text-heading uppercase tracking-wider mb-4">
          {lang === "de" ? "Navigation" : "Navigation"}
        </h4>
        <ul class="space-y-3">
          <li>
            <a href="#features" class="text-text-muted hover:text-amber transition-colors duration-300 text-sm">
              {t("nav.features")}
            </a>
          </li>
          <li>
            <a href="#testimonials" class="text-text-muted hover:text-amber transition-colors duration-300 text-sm">
              {t("nav.testimonials")}
            </a>
          </li>
          <li>
            <a href="#contact" class="text-text-muted hover:text-amber transition-colors duration-300 text-sm">
              {t("nav.contact")}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text-heading uppercase tracking-wider mb-4">
          {lang === "de" ? "Rechtliches" : "Legal"}
        </h4>
        <ul class="space-y-3">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-text-muted hover:text-amber transition-colors duration-300 text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-border">
      <p class="text-sm text-text-muted">
        &copy; {year} Buqon. {t("footer.rights")}
      </p>
    </div>
  </div>
</footer>
