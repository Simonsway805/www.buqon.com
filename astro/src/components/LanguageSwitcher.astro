---
import { getLangFromUrl, getLocalizedPath } from "@/i18n/utils";
import { languages } from "@/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const otherLang = lang === "de" ? "en" : "de";
const otherPath = getLocalizedPath(Astro.url.pathname, otherLang);
---

<a
  href={otherPath}
  class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-border text-sm text-text-muted hover:text-text hover:border-amber transition-colors duration-300"
  aria-label={`Switch to ${languages[otherLang]}`}
>
  <span class="text-xs">{otherLang === "de" ? "🇩🇪" : "🇬🇧"}</span>
  <span class="uppercase tracking-wider">{otherLang}</span>
</a>
