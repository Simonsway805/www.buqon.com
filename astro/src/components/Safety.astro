---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="safety" class="relative py-12 md:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="safety-image relative order-2 md:order-1">
        <div class="absolute -inset-4 bg-gradient-to-bl from-amber/10 to-transparent rounded-2xl blur-2xl"></div>
        <img
          src="/images/safety-grillabend.jpg"
          alt="Buqon DINE - Safe Grilling"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="relative rounded-2xl w-full aspect-[4/3] object-cover shadow-2xl shadow-black/40"
        />
      </div>

      <div class="safety-text order-1 md:order-2">
        <div class="inline-flex items-center gap-3 mb-6 px-4 py-2 bg-amber/10 border border-amber/20 rounded-full">
          <svg class="w-5 h-5 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-amber text-sm font-medium">{lang === "de" ? "Geprüfte Sicherheit" : "Certified Safety"}</span>
        </div>

        <h2 class="text-3xl md:text-5xl font-display font-bold text-text-heading leading-tight mb-6">
          {t("safety.title")}
        </h2>
        <p class="text-lg text-text-muted leading-relaxed mb-8">
          {t("safety.body")}
        </p>

        <div class="flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <div class="mt-1 w-5 h-5 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-amber" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-text-muted">{lang === "de" ? "Temperatur neutral von außen" : "Temperature neutral on the outside"}</span>
          </div>
          <div class="flex items-start gap-3">
            <div class="mt-1 w-5 h-5 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-amber" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-text-muted">{lang === "de" ? "Kinderleichter Umbau" : "Easy conversion"}</span>
          </div>
          <div class="flex items-start gap-3">
            <div class="mt-1 w-5 h-5 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-amber" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-text-muted">{lang === "de" ? "Edelstahl Qualität" : "Stainless steel quality"}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from("#safety .safety-image", {
    x: -40,
    opacity: 0,
    duration: 0.7,
    ease: "power2.out",
    scrollTrigger: {
      trigger: "#safety",
      start: "top 85%",
    },
  });

  gsap.from("#safety .safety-text", {
    x: 40,
    opacity: 0,
    duration: 0.7,
    ease: "power2.out",
    scrollTrigger: {
      trigger: "#safety",
      start: "top 85%",
    },
  });
</script>
