---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const testimonials = [
  {
    name: "Karim",
    location: lang === "de" ? "Schweiz" : "Switzerland",
    avatar: "/images/avatars/karim.webp",
    quote:
      lang === "de"
        ? "Absolut cooles Grill-Erlebnis mit Freunden. Nicht mehr nur ein Grillmeister, der Abseits steht während die Gäste warten, nein alle grillen und haben Spaß miteinander. Mein neues Geschenk, der Grilltisch ist eine absolute Bereicherung und eine meiner besten Anschaffungen für den Garten."
        : "An absolutely cool grilling experience with friends. No more just one grill master standing aside while guests wait — everyone grills and has fun together. My new gift, the grill table, is an absolute enrichment and one of my best garden purchases.",
  },
  {
    name: "Susanne",
    location: lang === "de" ? "Österreich" : "Austria",
    avatar: "/images/avatars/susanne.webp",
    quote:
      lang === "de"
        ? "BUQON ist jeden Cent wert. Wir nutzen ihn je nach Bedarf als praktischen Gartentisch, als Getränkekühler oder als Grilltisch für feine gesellige Abende. Was wir lieben: mit diesem Tisch ist es möglich, dass ALLE gleichzeitig grillen, essen und genießen."
        : "BUQON is worth every cent. We use it as a practical garden table, drink cooler, or grill table for fine social evenings. What we love: with this table, it's possible for EVERYONE to grill, eat, and enjoy at the same time.",
  },
  {
    name: "Karoline",
    location: lang === "de" ? "Österreich" : "Austria",
    avatar: "/images/avatars/karoline.webp",
    quote:
      lang === "de"
        ? "Für mich ist das der perfekte Gartentisch. Ich sitz 'am Feuer' mit meinen Freunden und grill mir mein Lieblingsessen. Einfach perfekt. Ein Muss für jeden geselligen Grillfan."
        : "For me, this is the perfect garden table. I sit 'by the fire' with my friends and grill my favorite food. Simply perfect. A must for every sociable grill fan.",
  },
  {
    name: "Bernhard",
    location: lang === "de" ? "Österreich" : "Austria",
    avatar: "/images/avatars/bernhard.webp",
    quote:
      lang === "de"
        ? "Endlich muss ich nicht mehr alleine am Grill schwitzen und ständig vom Tisch weg, sondern kann gemütlich mit meinen Freunden zusammen das Grillen genießen. Dazu noch ein kühles Bier aus der Eiswanne – traumhaft!"
        : "Finally, I no longer have to sweat alone at the grill and constantly leave the table. Instead, I can comfortably enjoy grilling together with my friends. Add a cold beer from the ice tray — wonderful!",
  },
];
---

<section id="testimonials" class="relative py-12 md:py-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg-surface/50 to-bg"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="reveal text-center mb-12">
      <h2 class="text-3xl md:text-5xl font-display font-bold text-text-heading">
        {t("testimonials.title")}
      </h2>
    </div>

    <div class="reveal relative max-w-2xl mx-auto">
      <div id="testimonial-carousel" class="relative overflow-hidden">
        {testimonials.map((item, i) => (
          <div
            class:list={["testimonial-slide absolute top-0 left-0 w-full transition-all duration-500 ease-out", i === 0 ? "opacity-100 translate-x-0" : "opacity-0 translate-x-8"]}
            data-index={i}
          >
            <div class="bg-bg-card border border-border rounded-2xl p-8 md:p-10">
              <div class="absolute top-8 right-8 text-6xl text-amber/10 font-display leading-none select-none">
                &ldquo;
              </div>

              <div class="flex items-center gap-4 mb-6">
                <img
                  src={item.avatar}
                  alt={item.name}
                  width="112"
                  height="112"
                  loading="lazy"
                  decoding="async"
                  class="w-14 h-14 rounded-full object-cover ring-2 ring-amber/20"
                />
                <div>
                  <h4 class="font-semibold text-text-heading">{item.name}</h4>
                  <p class="text-sm text-text-muted">{item.location}</p>
                </div>
              </div>

              <p class="text-text-muted leading-relaxed relative z-10">
                {item.quote}
              </p>

              <div class="flex gap-1 mt-6">
                {[...Array(5)].map(() => (
                  <svg class="w-4 h-4 text-amber" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="flex items-center justify-center gap-3 mt-5 md:mt-8">
        <button id="testimonial-prev" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text-muted hover:text-amber hover:border-amber/30 transition-colors" aria-label="Previous">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <div class="flex gap-2" id="testimonial-dots">
          {testimonials.map((_, i) => (
            <button
              class:list={["w-2.5 h-2.5 rounded-full transition-all duration-300", i === 0 ? "bg-amber w-6" : "bg-border hover:bg-text-muted"]}
              data-dot={i}
              aria-label={`Review ${i + 1}`}
            />
          ))}
        </div>

        <button id="testimonial-next" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text-muted hover:text-amber hover:border-amber/30 transition-colors" aria-label="Next">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>(".testimonial-slide");
  const dots = document.querySelectorAll<HTMLElement>("[data-dot]");
  const total = slides.length;
  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;

  function setHeight() {
    const carousel = document.getElementById("testimonial-carousel")!;
    const activeSlide = slides[current];
    carousel.style.height = activeSlide.scrollHeight + "px";
  }

  function goTo(index: number) {
    const prev = current;
    current = ((index % total) + total) % total;
    const direction = current > prev || (prev === total - 1 && current === 0) ? 1 : -1;

    slides.forEach((slide, i) => {
      slide.classList.remove("opacity-100", "translate-x-0", "opacity-0", "translate-x-8", "-translate-x-8");
      if (i === current) {
        slide.classList.add("opacity-100", "translate-x-0");
      } else if (i === prev) {
        slide.classList.add("opacity-0", direction > 0 ? "-translate-x-8" : "translate-x-8");
      } else {
        slide.classList.add("opacity-0", "translate-x-8");
      }
    });

    dots.forEach((dot, i) => {
      dot.classList.toggle("bg-amber", i === current);
      dot.classList.toggle("w-6", i === current);
      dot.classList.toggle("bg-border", i !== current);
      dot.classList.toggle("w-2.5", i !== current);
    });

    setHeight();
  }

  function startAutoplay() {
    autoplayTimer = setInterval(() => goTo(current + 1), 5000);
  }

  function resetAutoplay() {
    clearInterval(autoplayTimer);
    startAutoplay();
  }

  document.getElementById("testimonial-prev")!.addEventListener("click", () => { goTo(current - 1); resetAutoplay(); });
  document.getElementById("testimonial-next")!.addEventListener("click", () => { goTo(current + 1); resetAutoplay(); });
  dots.forEach((dot) => {
    dot.addEventListener("click", () => { goTo(Number(dot.dataset.dot)); resetAutoplay(); });
  });

  setHeight();
  startAutoplay();
  window.addEventListener("resize", setHeight);
</script>
