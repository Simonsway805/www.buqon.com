---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isHome = Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`;
const anchor = (hash: string) => isHome ? hash : `/${lang}/${hash}`;
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`/${lang}/`} class="flex items-center gap-2 group">
      <span class="text-2xl font-bold tracking-tight text-text-heading font-display group-hover:text-amber transition-colors duration-300">
        BUQON
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href={anchor("#features")} class="nav-link text-sm tracking-wide text-text-muted hover:text-amber transition-colors duration-300">
        {t("nav.features")}
      </a>
      <a href={anchor("#testimonials")} class="nav-link text-sm tracking-wide text-text-muted hover:text-amber transition-colors duration-300">
        {t("nav.testimonials")}
      </a>
      <a href={anchor("#contact")} class="nav-link text-sm tracking-wide text-text-muted hover:text-amber transition-colors duration-300">
        {t("nav.contact")}
      </a>
    </div>

    <div class="flex items-center gap-4">
      <LanguageSwitcher />
      <a
        href={anchor("#contact")}
        class="hidden sm:inline-flex items-center px-5 py-2.5 bg-amber text-bg font-semibold text-sm rounded-full hover:bg-amber-light transition-colors duration-300"
      >
        {t("nav.inquiry")}
      </a>
      <button
        id="mobile-menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Menu"
      >
        <span class="block w-6 h-0.5 bg-text transition-transform duration-300" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-text transition-opacity duration-300" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-text transition-transform duration-300" id="bar3"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden bg-bg-surface/95 backdrop-blur-xl border-t border-border"
  >
    <div class="flex flex-col items-center gap-6 py-8">
      <a href={anchor("#features")} class="mobile-nav-link text-lg text-text-muted hover:text-amber transition-colors">
        {t("nav.features")}
      </a>
      <a href={anchor("#testimonials")} class="mobile-nav-link text-lg text-text-muted hover:text-amber transition-colors">
        {t("nav.testimonials")}
      </a>
      <a href={anchor("#contact")} class="mobile-nav-link text-lg text-text-muted hover:text-amber transition-colors">
        {t("nav.contact")}
      </a>
      <a
        href={anchor("#contact")}
        class="inline-flex items-center px-6 py-3 bg-amber text-bg font-semibold rounded-full"
      >
        {t("nav.inquiry")}
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar")!;

  window.addEventListener("scroll", () => {
    if (window.scrollY > 80) {
      navbar.classList.add("bg-bg/90", "backdrop-blur-xl", "shadow-lg", "shadow-black/20");
    } else {
      navbar.classList.remove("bg-bg/90", "backdrop-blur-xl", "shadow-lg", "shadow-black/20");
    }
  }, { passive: true });

  const mobileBtn = document.getElementById("mobile-menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;
  let isOpen = false;

  function toggleMenu(open: boolean) {
    isOpen = open;
    mobileMenu.classList.toggle("hidden", !open);
    bar1.style.transform = open ? "rotate(45deg) translateY(8px)" : "";
    bar2.style.opacity = open ? "0" : "1";
    bar3.style.transform = open ? "rotate(-45deg) translateY(-8px)" : "";
  }

  mobileBtn.addEventListener("click", () => toggleMenu(!isOpen));

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => toggleMenu(false));
  });
</script>
