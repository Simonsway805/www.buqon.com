---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="feature-quality" class="relative py-12 md:py-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg-surface to-bg"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="reveal-left">
        <span class="inline-block text-amber text-sm font-medium tracking-[0.2em] uppercase mb-4">
          04
        </span>
        <h2 class="text-3xl md:text-5xl font-display font-bold text-text-heading leading-tight mb-6">
          {t("feature.quality.title")}
        </h2>
        <p class="text-lg text-text-muted leading-relaxed mb-8">
          {t("feature.quality.body")}
        </p>

        <div class="grid grid-cols-3 gap-6">
          <div class="text-center">
            <span class="block text-3xl md:text-4xl font-bold text-amber font-display counter" data-target="100">100</span>
            <span class="block text-sm text-text-muted mt-1">% European</span>
          </div>
          <div class="text-center">
            <span class="block text-3xl md:text-4xl font-bold text-amber font-display counter" data-target="316">316</span>
            <span class="block text-sm text-text-muted mt-1">Stainless Steel</span>
          </div>
          <div class="text-center">
            <span class="block text-3xl md:text-4xl font-bold text-amber font-display counter" data-target="10">10</span>
            <span class="block text-sm text-text-muted mt-1">{getLangFromUrl(Astro.url) === "de" ? "Jahre Garantie" : "Years Warranty"}</span>
          </div>
        </div>
      </div>

      <div class="reveal-right relative">
        <div class="absolute -inset-4 bg-gradient-to-br from-amber/10 to-transparent rounded-2xl blur-2xl"></div>
        <img
          src="/images/gartentisch-grilleinsatz-8.webp"
          alt="Buqon DINE - Made in Europe"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="relative rounded-2xl w-full aspect-[4/3] object-cover shadow-2xl shadow-black/40"
        />
      </div>
    </div>
  </div>
</section>
