<section id="video" class="relative py-8 md:py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div id="video-embed" class="reveal-scale relative rounded-2xl overflow-hidden aspect-video bg-bg-card shadow-2xl shadow-black/40 cursor-pointer group">
      <img
        id="video-thumb"
        src="https://fast.wistia.com/embed/medias/6menz02dih/swatch"
        alt="Buqon DINE Video"
        width="1280"
        height="720"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div id="video-play" class="absolute inset-0 flex items-center justify-center z-10">
        <div class="w-16 h-16 md:w-20 md:h-20 bg-amber/90 rounded-full flex items-center justify-center shadow-lg group-hover:bg-amber group-hover:scale-110 transition-all duration-300">
          <svg class="w-6 h-6 md:w-8 md:h-8 text-bg ml-1" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      </div>
      <div id="video-wistia" class="hidden absolute inset-0"></div>
    </div>
  </div>
</section>

<script>
  let videoLoaded = false;
  document.getElementById("video-embed")?.addEventListener("click", () => {
    if (videoLoaded) return;
    videoLoaded = true;

    const container = document.getElementById("video-wistia")!;
    container.classList.remove("hidden");
    container.innerHTML = `
      <div class="wistia_responsive_padding" style="padding:56.25% 0 0 0;position:relative;">
        <div class="wistia_responsive_wrapper" style="height:100%;left:0;position:absolute;top:0;width:100%;">
          <div class="wistia_embed wistia_async_6menz02dih seo=false videoFoam=true autoPlay=true" style="height:100%;position:relative;width:100%;"></div>
        </div>
      </div>`;

    const s1 = document.createElement("script");
    s1.src = "https://fast.wistia.com/embed/medias/6menz02dih.jsonp";
    s1.async = true;
    const s2 = document.createElement("script");
    s2.src = "https://fast.wistia.com/assets/external/E-v1.js";
    s2.async = true;
    document.head.appendChild(s1);
    document.head.appendChild(s2);

    document.getElementById("video-thumb")?.remove();
    document.getElementById("video-play")?.remove();
  });
</script>
